<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="24dp"
    android:keepScreenOn="true">

    <!-- Top row: helmet status + exit -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvRideHelmetIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪖"
            android:textSize="36sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvRideHelmetStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="กำลังตรวจสอบ..."
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRideExit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="ออก"
            android:textSize="16sp"
            android:textColor="@color/white" />

    </LinearLayout>

    <!-- Central mic — the whole point of riding mode -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRideMic"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:text="🎤"
            android:textSize="88sp"
            android:textColor="@color/white"
            app:cornerRadius="110dp"
            app:backgroundTint="@color/purple_500" />

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="แตะเพื่อฟัง"
        android:textColor="#DDFFFFFF"
        android:textSize="20sp"
        android:layout_marginTop="20dp" />

    <!-- Last action / STT — big enough to glance at a stoplight -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#1F1F1F"
        app:cardCornerRadius="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ครั้งล่าสุด"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvRideLastAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ยังไม่มีคำสั่ง"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvRideLastHeard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCFFFFFF"
                android:textSize="16sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
